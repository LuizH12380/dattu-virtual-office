# ─── Cérebro dos agents ──────────────────────────────────────────────
# O escritório usa o CLAUDE CODE em modo headless (`claude -p`) como cérebro.
# É coberto pela sua ASSINATURA do Claude Code — NÃO precisa de API key.
# (Opcional) caminho do executável, se não estiver no PATH:
# CLAUDE_BIN=claude
# (Opcional) timeout por chamada em ms (default 120000):
# CLAUDE_TIMEOUT_MS=120000

# Porta do servidor web do escritório
PORT=3050

# Caminho absoluto do vault do Obsidian
# Se deixar vazio, usa o vault local em ./vault/
OBSIDIAN_VAULT_PATH=

# Nome da empresa (usado pelos agentes)
COMPANY_NAME=Dattu

# Integração com Dattu CRM (opcional)
DATTU_API_URL=http://localhost:3000/v1
DATTU_API_TOKEN=
