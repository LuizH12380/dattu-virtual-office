# Chave da API Anthropic (Claude)
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Modelo Claude a usar (recomendado: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Caminho absoluto do vault do Obsidian
# Se deixar vazio, usa o vault local em ./vault/
OBSIDIAN_VAULT_PATH=

# Nome da empresa (usado pelos agentes)
COMPANY_NAME=Dattu

# Integração com Dattu CRM (opcional)
DATTU_API_URL=http://localhost:3000/v1
DATTU_API_TOKEN=
